{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/memox-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxAppBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|large|leading|trailing|node|className|key|ref|className|style|children)$/]",
        "message": "<MxAppBar> doesn't accept that prop. Declared props: title, eyebrow, large, leading, trailing, node, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|variant|ring|node|key|ref|className|style|children)$/]",
        "message": "<MxAvatar> doesn't accept that prop. Declared props: name, src, size, variant, ring, node."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxAvatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<MxAvatar> size must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxAvatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent)$/]",
        "message": "<MxAvatar> variant must be one of 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|soft|dot|node|key|ref|className|style|children)$/]",
        "message": "<MxBadge> doesn't accept that prop. Declared props: children, tone, soft, dot, node."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|error)$/]",
        "message": "<MxBadge> tone must be one of 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxBottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<MxBottomNavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|trailingIcon|block|danger|disabled|node|className|children|onClick|type|key|ref|className|style|children)$/]",
        "message": "<MxButton> doesn't accept that prop. Declared props: variant, size, icon, trailingIcon, block, danger, disabled, node, className, children, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|contrast)$/]",
        "message": "<MxButton> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'contrast'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<MxButton> size must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxButton'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<MxButton> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|interactive|padding|node|className|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MxCard> doesn't accept that prop. Declared props: variant, interactive, padding, node, className, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:flat|muted|primary|primary-soft)$/]",
        "message": "<MxCard> variant must be one of 'flat' | 'muted' | 'primary' | 'primary-soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxCard'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<MxCard> padding must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|selected|variant|node|onClick|children|key|ref|className|style|children)$/]",
        "message": "<MxChip> doesn't accept that prop. Declared props: label, icon, selected, variant, node, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxChip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|ghost)$/]",
        "message": "<MxChip> variant must be one of 'accent' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxFab'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|round|node|onClick|key|ref|className|style|children)$/]",
        "message": "<MxFab> doesn't accept that prop. Declared props: icon, label, variant, round, node, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxFab'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent)$/]",
        "message": "<MxFab> variant must be one of 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|node|className|onClick|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<MxIconButton> doesn't accept that prop. Declared props: icon, variant, size, node, className, onClick, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|primary)$/]",
        "message": "<MxIconButton> variant must be one of 'filled' | 'primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm)$/]",
        "message": "<MxIconButton> size must be one of 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|solid|node|className|key|ref|className|style|children)$/]",
        "message": "<MxIconTile> doesn't accept that prop. Declared props: icon, tone, size, solid, node, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|success|warning|error)$/]",
        "message": "<MxIconTile> tone must be one of 'accent' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxIconTile'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg)$/]",
        "message": "<MxIconTile> size must be one of 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxScaffold'] > JSXAttribute > JSXIdentifier[name!=/^(?:appBar|bottomNav|fab|children|flush|node|className|style|key|ref|className|style|children)$/]",
        "message": "<MxScaffold> doesn't accept that prop. Declared props: appBar, bottomNav, fab, children, flush, node, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxSearchDock'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|focused|flat|trailing|node|key|ref|className|style|children)$/]",
        "message": "<MxSearchDock> doesn't accept that prop. Declared props: placeholder, value, onChange, focused, flat, trailing, node."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxSectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|caption|action|onAction|node|key|ref|className|style|children)$/]",
        "message": "<MxSectionHeader> doesn't accept that prop. Declared props: title, caption, action, onAction, node."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<MxSegment> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='MxSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|node|key|ref|className|style|children)$/]",
        "message": "<MxSwitch> doesn't accept that prop. Declared props: checked, disabled, onChange, node."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
