#!/bin/sh
# post-merge — after `main` updates (git pull / merge), push any kit changes that
# landed on main up to the Claude Design project.
#
# Why this exists (the gap pre-push can't cover): PRs are merged server-side and
# agent pushes bypass pre-push (MEMOX_SKIP_DESIGN_SYNC=1), so kit edits reach
# `main` without ever syncing to Claude Design. This hook fires when the local
# `main` receives those commits and closes the loop — comparing against the
# recorded `lastSyncedCommit`, not just this merge, so it catches everything
# still unsynced. Runs in RECORD mode so it advances lastSyncedCommit.
#
# Bypass: MEMOX_SKIP_DESIGN_SYNC=1 git pull   (agent sessions without a
# design-authorized TTY MUST use this, or the nested `claude` hangs).
set -e

[ "$MEMOX_SKIP_DESIGN_SYNC" = "1" ] && exit 0
command -v node >/dev/null 2>&1 || exit 0
[ -f .design-sync/config.json ] || exit 0

# only on main — feature-branch merges/pulls are not the sync point
branch=$(git symbolic-ref --short -q HEAD 2>/dev/null || echo '')
[ "$branch" = "main" ] || exit 0

LOCALDIR=$(node -e "try{process.stdout.write((JSON.parse(require('fs').readFileSync('.design-sync/config.json','utf8')).localDir)||'')}catch(e){}")
LAST=$(node -e "try{process.stdout.write((JSON.parse(require('fs').readFileSync('.design-sync/config.json','utf8')).lastSyncedCommit)||'')}catch(e){}")
[ -n "$LOCALDIR" ] || exit 0
[ -n "$LAST" ] || exit 0

# nothing to do unless the kit changed since the last recorded sync
[ -n "$(git diff --name-only "$LAST"..HEAD -- "$LOCALDIR" 2>/dev/null)" ] || exit 0

if ! command -v claude >/dev/null 2>&1; then
  echo "post-merge: ⚠ kit changed on main since last Claude Design sync ($LAST) but \`claude\` CLI not found." >&2
  echo "post-merge:   run \`node scripts/sync-design.js\` from a design-authorized terminal to push it up." >&2
  exit 0
fi

echo "post-merge: kit changed on main since $LAST — pushing to Claude Design…"
node scripts/sync-design.js   # record mode: advances lastSyncedCommit
exit 0
