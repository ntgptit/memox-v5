#!/bin/sh
# pre-push — last local gate before code leaves the machine.
#
#  1. verify gate — run the full `npm run check` (tsc + Biome + Jest + boundaries).
#  2. design sync — if the pushed range changes files under the kit localDir
#     (.design-sync/config.json), push that delta UP to the Claude Design project
#     via scripts/sync-design.js (drives the design-authorized `claude` CLI).
#
# Server-side PR merges + agent pushes (MEMOX_SKIP_DESIGN_SYNC=1) skip the design
# sync; `.githooks/post-merge` catches kit changes when `main` updates.
#
# Bypass verify:      MEMOX_SKIP_VERIFY=1 git push
# Bypass design sync: MEMOX_SKIP_DESIGN_SYNC=1 git push
# Bypass everything:  git push --no-verify
#
# Requires core.hooksPath=.githooks (see docs/design/design-sync-process.md).
set -e

if ! command -v node >/dev/null 2>&1; then
  echo "pre-push: node not found; skipping checks." >&2
  exit 0
fi

# 1. verify gate ------------------------------------------------------------
# Skipped for automated pushes that gate themselves (MEMOX_SKIP_DESIGN_SYNC=1)
# or via an explicit MEMOX_SKIP_VERIFY=1 bypass.
if [ "$MEMOX_SKIP_VERIFY" != "1" ] && [ "$MEMOX_SKIP_DESIGN_SYNC" != "1" ]; then
  echo "pre-push: running \`npm run check\`…"
  npm run check
fi

# 2. design sync on push ----------------------------------------------------
[ "$MEMOX_SKIP_DESIGN_SYNC" = "1" ] && exit 0
[ -f .design-sync/config.json ] || exit 0
if ! command -v claude >/dev/null 2>&1; then
  echo "pre-push: \`claude\` CLI not found; skipping design sync (run \`node scripts/sync-design.js\` from a design-authorized CLI)." >&2
  exit 0
fi

LOCALDIR=$(node -e "try{process.stdout.write((JSON.parse(require('fs').readFileSync('.design-sync/config.json','utf8')).localDir)||'')}catch(e){}")
[ -n "$LOCALDIR" ] || exit 0

zero=0000000000000000000000000000000000000000
# git feeds ref updates on stdin: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue                 # branch deletion
  if [ "$remote_sha" = "$zero" ]; then
    echo "pre-push: new branch — syncing design delta since last recorded sync…"
    node scripts/sync-design.js --no-record
  else
    if [ -n "$(git diff --name-only "$remote_sha".."$local_sha" -- "$LOCALDIR")" ]; then
      echo "pre-push: design kit changed in ${remote_sha}..${local_sha} — pushing to Claude Design…"
      node scripts/sync-design.js "$remote_sha" --no-record
    fi
  fi
done

exit 0
